# Spellbrawl environment variables
# Copy to .env.local for development. Set the same keys in Vercel → Project → Settings → Environment Variables.

# Supabase (required for auth + cloud progress)
VITE_SUPABASE_URL=https://nunlfinypmuktgyzfult.supabase.co
VITE_SUPABASE_ANON_KEY=your_publishable_anon_key

# Cloudflare Workers party server (required for online room battles)
# Local: wrangler dev on port 8787. Production: your *.workers.dev host.
VITE_PARTYKIT_HOST=localhost:8787

# Server-only (set in shell for wrangler deploy — NEVER commit tokens)
# CLOUDFLARE_ACCOUNT_ID=your_account_id
# CLOUDFLARE_API_TOKEN=your_api_token
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
