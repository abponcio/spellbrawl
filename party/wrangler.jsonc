{
  "$schema": "../node_modules/wrangler/config-schema.json",
  "name": "spellbrawl-party",
  "main": "worker.ts",
  "compatibility_date": "2024-11-01",
  "compatibility_flags": ["nodejs_compat"],
  "durable_objects": {
    "bindings": [
      {
        "name": "Spellbrawl",
        "class_name": "SpellbrawlRoom"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["SpellbrawlRoom"]
    }
  ]
}
